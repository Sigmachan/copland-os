#!/bin/sh
# prime-run <command> -- run a command explicitly on the NVIDIA dGPU (RTX 5090)
# via PRIME render offload. On this build the 5090 is already the primary GPU, so
# this mainly forces the NVIDIA Vulkan/GLX vendor for apps that would otherwise
# pick the AMD iGPU render node.
export __NV_PRIME_RENDER_OFFLOAD=1
export __NV_PRIME_RENDER_OFFLOAD_PROVIDER=NVIDIA-G0
export __GLX_VENDOR_LIBRARY_NAME=nvidia
export __VK_LAYER_NV_optimus=NVIDIA_only
export VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/nvidia_icd.json
exec "$@"
