#!/usr/bin/env bash
# blackwell-ai-setup -- provision vLLM + a vLLM playground for the RTX 5090 (Blackwell sm_120).
#
# Why on-demand and not baked into the ISO: vLLM has no CUDA Arch package and pulls a
# PyTorch built for sm_120 (CUDA 12.8+, multi-GB). Baking that would bloat the ISO and
# pin a torch version, so it is installed into a dedicated venv on first run instead.
#
# llama.cpp (Blackwell) is already installed system-wide as the `llama.cpp-blackwell`
# package -> use `llama-server` / `llama-cli` / `llama-bench` directly, no setup needed.
set -euo pipefail

ROOT=/opt/blackwell-ai
VENV="$ROOT/vllm"
PLAYGROUND="$ROOT/vllm-playground"
TORCH_INDEX="https://download.pytorch.org/whl/cu128"

echo ">> Blackwell AI provisioning (vLLM + playground) into $ROOT"
sudo install -d -o "$USER" -g "$USER" "$ROOT"

if [ ! -d "$VENV" ]; then
    python -m venv "$VENV"
fi
# shellcheck disable=SC1091
source "$VENV/bin/activate"
pip install --upgrade pip wheel
# PyTorch with Blackwell (sm_120) kernels, then vLLM against it.
pip install --index-url "$TORCH_INDEX" torch torchvision torchaudio
pip install vllm gradio openai

# Minimal "playground": a Gradio chat UI that talks to the local vLLM OpenAI endpoint.
install -d "$PLAYGROUND"
cat > "$PLAYGROUND/playground.py" <<'PY'
import os, gradio as gr
from openai import OpenAI
client = OpenAI(base_url=os.environ.get("VLLM_URL", "http://127.0.0.1:8000/v1"), api_key="local")
MODEL = os.environ.get("VLLM_MODEL", "served-model")
def chat(msg, history):
    msgs = [{"role": "user", "content": msg}]
    out = client.chat.completions.create(model=MODEL, messages=msgs, stream=True)
    acc = ""
    for c in out:
        d = c.choices[0].delta.content or ""
        acc += d
        yield acc
gr.ChatInterface(chat, title="vLLM Playground (RTX 5090 / Blackwell)").launch(server_name="0.0.0.0", server_port=7860)
PY

cat <<EOF

Done. Blackwell AI stack ready:
  llama.cpp (system) : llama-server -m <model.gguf> -ngl 99      # proven 78 t/s on 27B-Q4
  vLLM serve         : $VENV/bin/vllm serve <hf-model> --gpu-memory-utilization 0.9
  vLLM playground    : VLLM_MODEL=<name> $VENV/bin/python $PLAYGROUND/playground.py  (http://localhost:7860)
EOF
