#!/usr/bin/env bash
# gcx-layout — Zorin-Appearance-style desktop layout switcher for GNOME.
# Applies a whole layout preset (dock + window buttons) via gsettings in one shot.
# Open-coded equivalent of Zorin's feature (Zorin's app is not Arch-packaged); no Zorin assets used.
# Usage: gcx-layout <macos|windows|gnome>
set -u
DTD="org.gnome.shell.extensions.dash-to-dock"
WM="org.gnome.desktop.wm.preferences"
have_dtd(){ gsettings list-schemas 2>/dev/null | grep -q "^$DTD$"; }
set_dtd(){ have_dtd && gsettings set "$DTD" "$1" "$2" 2>/dev/null || true; }

case "${1:-}" in
  macos)
    # bottom, centered, floating, auto-hide (the user's COSMIC/macOS look); buttons on the LEFT
    set_dtd dock-position BOTTOM; set_dtd extend-height false; set_dtd dock-fixed false
    set_dtd autohide true; set_dtd intellihide-mode "'FOCUS_APPLICATION'"
    set_dtd transparency-mode "'DYNAMIC'"; set_dtd custom-theme-shrink true
    gsettings set "$WM" button-layout 'close,minimize,maximize:'
    ;;
  windows)
    # full-width bottom taskbar, always visible; buttons on the RIGHT
    set_dtd dock-position BOTTOM; set_dtd extend-height true; set_dtd dock-fixed true
    set_dtd autohide false; set_dtd transparency-mode "'DEFAULT'"; set_dtd show-apps-at-top false
    gsettings set "$WM" button-layout ':minimize,maximize,close'
    ;;
  gnome)
    # vanilla GNOME: left intellihide dash, default appmenu:close buttons
    set_dtd dock-position LEFT; set_dtd extend-height true; set_dtd dock-fixed false
    set_dtd autohide true; set_dtd transparency-mode "'DEFAULT'"
    gsettings set "$WM" button-layout 'appmenu:close'
    ;;
  *)
    echo "Usage: gcx-layout <macos|windows|gnome>"; exit 2 ;;
esac
echo "Applied '$1' layout."
