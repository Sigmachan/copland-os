#!/bin/sh
# igpu-run <command> -- run a command on the AMD RDNA2 iGPU instead of the 5090.
# Use for light apps / video playback (RADV + RDNA2 VA-API) to keep the dGPU's
# VRAM and compute free for games or LLM inference running on the 5090.
export DRI_PRIME=1
export __GLX_VENDOR_LIBRARY_NAME=mesa
export __EGL_VENDOR_LIBRARY_FILENAMES=/usr/share/glvnd/egl_vendor.d/50_mesa.json
export VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/radeon_icd.x86_64.json
export LIBVA_DRIVER_NAME=radeonsi
exec "$@"
