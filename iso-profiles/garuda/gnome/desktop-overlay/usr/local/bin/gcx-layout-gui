#!/usr/bin/env bash
# gcx-layout-gui — 2-click layout picker (Zorin-Appearance-style). Pick a layout, it applies.
set -u
choice=$(zenity --list --radiolist --title="Desktop Layout" \
  --width=420 --height=260 \
  --text="Pick a desktop layout (changes dock + window buttons instantly):" \
  --column="" --column="Layout" --column="Description" \
  TRUE  macos   "macOS — centered auto-hide bottom dock, buttons left" \
  FALSE windows "Windows — full-width bottom taskbar, buttons right" \
  FALSE gnome   "GNOME — vanilla left dash, default buttons" \
  2>/dev/null) || exit 0
[ -n "$choice" ] && gcx-layout "$choice" && \
  zenity --info --no-wrap --title="Desktop Layout" --text="Applied the <b>$choice</b> layout." 2>/dev/null || true
