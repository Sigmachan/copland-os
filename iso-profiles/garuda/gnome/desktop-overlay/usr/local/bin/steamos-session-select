#!/bin/bash
# GNOME-correct steamos-session-select for the Garuda GNOME x CachyOS ISO.
#
# The packaged /usr/bin/steamos-session-select (gamescope-session-cachyos) targets the Steam Deck
# stack: it calls `steam-set-session plasma.desktop` and `qdbus6 org.kde.Shutdown` — i.e. it assumes
# KDE Plasma + SDDM. This ISO ships GNOME + GDM, so that return-to-desktop path is wrong.
# /usr/local/bin precedes /usr/bin in PATH, so Steam's "Switch to Desktop" resolves to this wrapper.
set -e
mode="${1:-}"
case "$mode" in
    plasma|desktop)
        # "Switch to Desktop" from Steam Game Mode: shut Steam down and end the gamescope session.
        # The user lands back at the GDM greeter where GNOME is the default session.
        steam -shutdown 2>/dev/null || true
        systemctl --user stop gamescope-session.target 2>/dev/null || true
        ;;
    gamescope)
        # Enter Game Mode now: end the current GNOME session and return to GDM, where the
        # "Gamescope" session can be selected (GDM remembers the last-used session per user).
        gnome-session-quit --logout --no-prompt 2>/dev/null \
            || loginctl terminate-session "${XDG_SESSION_ID:-self}" 2>/dev/null || true
        ;;
    persistent|oneshot)
        # No-op on a GDM desktop: the session is chosen at the GDM greeter (GNOME is default).
        # Unlike a handheld, this desktop ISO does not auto-boot into Game Mode.
        : ;;
    *)
        cat <<EOF
GNOME steamos-session-select (Garuda x CachyOS):
  plasma | desktop   return to the GNOME desktop (stop Steam + gamescope session -> GDM)
  gamescope          enter Game Mode (log out of GNOME -> pick "Gamescope" at GDM)
  persistent|oneshot no-op (session chosen at the GDM greeter on this desktop)
EOF
        [ -n "$mode" ] && exit 1 || exit 0 ;;
esac
