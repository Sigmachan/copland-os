#!/bin/bash
# dlss-swapper — Bazzite-compatible Steam launch wrapper.
# Add `dlss-swapper %command%` to a game's Steam launch options to force the LATEST DLSS presets and
# enable DLSS Super Resolution / Ray Reconstruction / Frame Generation overrides for THAT game —
# i.e. update/swap DLSS inside the game with no file edits. RTX/DX12/DXR are already on by default
# in modern Proton+vkd3d; FSR is available via gamescope (-F fsr) and per-game. This is the opt-in
# "use newest DLSS + frame-gen" switch (kept per-game, not global, to avoid forcing FG where unwanted).
export PROTON_ENABLE_NVAPI=1
export PROTON_ENABLE_NGX_UPDATER=1
export DXVK_NVAPI_DRS_SETTINGS="NGX_DLSS_SR_OVERRIDE=on,NGX_DLSS_RR_OVERRIDE=on,NGX_DLSS_FG_OVERRIDE=on,NGX_DLSS_SR_OVERRIDE_RENDER_PRESET_SELECTION=render_preset_latest,NGX_DLSS_RR_OVERRIDE_RENDER_PRESET_SELECTION=render_preset_latest"
exec "$@"
